{
  "version": 1,
  "description": "情报质量过滤规则。目标是减少 Notion 噪音，只保留能形成判断、预警、竞品信号、机会清单或面试案例的内容。",
  "quality_thresholds": {
    "notion_min_final_score": 3.8,
    "report_min_final_score": 3.2,
    "min_confidence_for_notion": "medium",
    "require_actionable_for_notion": true,
    "max_items_per_day_to_notion": 30
  },
  "actionable_actions": [
    "track_follow_up",
    "create_product_insight",
    "convert_to_interview_story",
    "save_to_knowledge_base"
  ],
  "strong_event_types": [
    "policy_regulation",
    "shutdown_or_removal",
    "security_safety_risk",
    "pricing_change",
    "product_launch",
    "standard_update",
    "case_study",
    "hiring_signal"
  ],
  "weak_event_types": [
    "market_opinion",
    "other"
  ],
  "title_noise_keywords": [
    "一文看懂",
    "重磅",
    "炸裂",
    "震惊",
    "万字长文",
    "终于",
    "来了",
    "王炸",
    "爆火",
    "必看",
    "收藏",
    "干货",
    "速览",
    "盘点",
    "周报",
    "日报"
  ],
  "generic_sentence_blacklist": [
    "可转成面试表达",
    "适合转化为",
    "建议进一步拆解",
    "暂时更适合作为行业背景材料",
    "不能只看热闹",
    "建议归档并观察后续变化"
  ],
  "drop_rules": [
    {
      "id": "low_score",
      "description": "总分低于 Notion 阈值，不进入 Notion。"
    },
    {
      "id": "weak_signal_without_confirmation",
      "description": "社媒/招聘/市场观点类弱信号，如果没有中高置信度，不进入 Notion。"
    },
    {
      "id": "no_actionable_value",
      "description": "没有 follow_up、product_insight、interview_story、knowledge_base 动作的内容，不进入 Notion。"
    },
    {
      "id": "generic_summary_only",
      "description": "只有模板化句子，没有具体政策、产品、公司、价格、功能、招聘或风险变化，不进入 Notion。"
    }
  ],
  "keep_rules": [
    {
      "id": "strong_policy_or_risk",
      "description": "政策监管、下架整改、安全风险，即使证据不完整，也保留为待验证事件。"
    },
    {
      "id": "official_product_change",
      "description": "官方产品发布、Changelog、GitHub Release、价格/限流变化，优先保留。"
    },
    {
      "id": "cross_source_signal",
      "description": "同一事件有多个来源交叉验证，优先保留。"
    },
    {
      "id": "career_or_business_asset",
      "description": "能明确转成面试案例、商业机会、竞品应对或企业合规服务的内容，保留。"
    }
  ]
}
