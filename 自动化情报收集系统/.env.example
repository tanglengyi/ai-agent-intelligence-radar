# RSSHub
# 推荐后续自建 RSSHub；不配置时默认使用 https://rsshub.app
RSSHUB_BASE_URL=https://rsshub.app

# LLM three-sentence summary
# 支持 OpenAI-compatible /v1/chat/completions 服务
OPENAI_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
ENABLE_LLM=0

# Notion sync
# 新版 Notion 建议使用 NOTION_DATA_SOURCE_ID；旧数据库也可尝试 NOTION_DATABASE_ID
NOTION_TOKEN=
NOTION_DATA_SOURCE_ID=
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28
ENABLE_NOTION_SYNC=0
